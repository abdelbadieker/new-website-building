generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  firstName       String
  lastName        String
  businessName    String
  phone           String?
  wilaya          String?
  isActive        Boolean   @default(false)
  planTier        String    @default("starter")
  googleId        String?   @unique
  avatarUrl       String?
  ipAddress       String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  features         FeatureToggle[]
  orders           Order[]
  customers        Customer[]
  products         Product[]
  notifications    Notification[]
  subscriptions    Subscription[]
  activityLogs     ActivityLog[]
  fulfillmentItems FulfillmentItem[]
}

model FeatureToggle {
  id         String   @id @default(cuid())
  merchantId String
  feature    String
  // "crm" | "ai_chatbot" | "ecotrack"
  // "fulfillment" | "analytics" | "creative_studio"
  // "web_creation" | "estore"
  isEnabled  Boolean  @default(false)
  enabledAt  DateTime?
  updatedAt  DateTime @updatedAt
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, feature])
}

model Order {
  id           String   @id @default(cuid())
  merchantId   String
  orderRef     String   @unique @default(cuid())
  customerName String
  phone        String
  wilaya       String
  address      String
  commune      String?
  products     Json
  total        Float
  status       String   @default("new")
  trackingCode String?
  carrier      String?
  isCOD        Boolean  @default(true)
  notes        String?
  sheetsSynced Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Customer {
  id          String   @id @default(cuid())
  merchantId  String
  name        String
  phone       String
  wilaya      String?
  email       String?
  totalOrders Int      @default(0)
  totalSpent  Float    @default(0)
  ltv         Float    @default(0)
  tags        String[]
  notes       String?
  lastOrderAt DateTime?
  createdAt   DateTime @default(now())
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Product {
  id           String   @id @default(cuid())
  merchantId   String
  name         String
  description  String?
  price        Float
  comparePrice Float?
  stock        Int      @default(0)
  images       String[]
  category     String?
  sku          String?
  variants     Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String   @id @default(cuid())
  merchantId   String
  plan         String
  status       String   // pending | active | expired | rejected
  paymentRef   String?
  paymentType  String?  // baridimob | ccp
  paymentProof String?
  startDate    DateTime?
  endDate      DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model FulfillmentItem {
  id          String   @id @default(cuid())
  merchantId  String
  productName String
  sku         String
  quantity    Int
  notes       String?
  receivedAt  DateTime @default(now())
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  merchantId String
  type       String   // new_order | stock_alert | video_ready | system | subscription
  title      String
  body       String
  isRead     Boolean  @default(false)
  actionUrl  String?
  createdAt  DateTime @default(now())
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Review {
  id           String   @id @default(cuid())
  merchantId   String?
  authorName   String
  businessName String?
  wilaya       String?
  rating       Int
  text         String
  isApproved   Boolean  @default(false)
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String
  actorRole String
  actorName String
  action    String
  target    String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model ContactInfo {
  id        String   @id @default(cuid())
  email     String
  phone     String
  whatsapp  String
  address   String?
  facebook  String?
  instagram String?
  updatedAt DateTime @updatedAt
}

model LandingSection {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   Json
  isVisible Boolean  @default(true)
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isVisible Boolean  @default(true)
}

model PartnerProject {
  id           String   @id @default(cuid())
  merchantId   String
  merchantName String
  businessName String
  partner      String   // sitewebdz | ma5zani
  type         String   // landing_page | estore
  status       String   // submitted | in_progress | review | live | paused
  liveUrl      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatbotConfig {
  id            String   @id @default(cuid())
  merchantId    String   @unique
  isActive      Boolean  @default(false)
  platforms     String[]
  language      String   @default("auto")
  greetingMsg   String?
  outOfStockMsg String?
  promoVideoUrl String?
  activatedAt   DateTime?
}
